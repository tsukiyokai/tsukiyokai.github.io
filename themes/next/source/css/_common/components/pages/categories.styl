.category-all-page {
  .category-all-title {
    text-align: center;
  }

  .category-all {
    margin-top: 20px;
  }

  .category-list {
    font-size: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .category-list-item {
    margin: 5px 10px;
  }

  .category-list-count {
    color: $grey;

    &::before {
      content: ' (';
    }

    &::after {
      content: ') ';
    }
  }

  .category-list-child {
    font-size: 15px;
    list-style: georgian outside url('/non-existent.svg');
    padding-left: 10px;
  }
}
